:root{font-family:Inter,ui-sans-serif,system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;color:#08111f;background:#f4f7fb;line-height:1.5}*{box-sizing:border-box}body{margin:0}button,input,select{font:inherit}button{cursor:pointer}.loginShell{min-height:100vh;display:grid;place-items:center;padding:28px;background:radial-gradient(circle at top left,#dbeafe,transparent 32%),linear-gradient(135deg,#020617,#111827)}.glass{background:rgba(255,255,255,.9);backdrop-filter:blur(22px);border:1px solid rgba(255,255,255,.35);box-shadow:0 30px 100px rgba(2,6,23,.35)}.loginCard{width:min(480px,100%);border-radius:34px;padding:38px}.logoMark,.brand span{display:grid;place-items:center;background:linear-gradient(135deg,#2563eb,#7c3aed);color:white;font-weight:900}.logoMark{width:62px;height:62px;border-radius:22px;margin-bottom:22px}.loginCard h1{font-size:36px;line-height:1.05;margin:8px 0 12px}.muted{color:#64748b}.tiny{font-size:12px;color:#94a3b8}.formGrid{display:grid;gap:14px;margin-top:24px}label{font-weight:750;color:#233044}input,select{width:100%;margin-top:7px;border:1px solid #dbe4ef;border-radius:16px;padding:13px 14px;background:#fff;outline:none;transition:.2s}input:focus,select:focus{border-color:#2563eb;box-shadow:0 0 0 4px rgba(37,99,235,.11)}.primary,.ghost,.small{border:0;border-radius:16px;padding:12px 18px;font-weight:850}.primary{background:linear-gradient(135deg,#2563eb,#1d4ed8);color:white;box-shadow:0 16px 36px rgba(37,99,235,.25)}.ghost{background:white;color:#08111f;border:1px solid #e2e8f0}.small{padding:8px 11px;background:#eef2ff;color:#1d4ed8}.full{width:100%}.app{display:grid;grid-template-columns:280px 1fr;min-height:100vh}.sidebar{position:sticky;top:0;height:100vh;background:#020617;color:white;padding:24px;display:flex;flex-direction:column;gap:10px}.brand{display:flex;align-items:center;gap:13px;margin-bottom:22px}.brand span{width:46px;height:46px;border-radius:16px}.brand strong{display:block;font-size:19px}.brand small{color:#93a4bc}.sidebar button{border:0;background:transparent;color:#b9c5d6;text-align:left;border-radius:16px;padding:14px 16px;font-weight:800;transition:.2s}.sidebar button:hover,.sidebar button.active{background:rgba(255,255,255,.1);color:white}.sideBox{margin-top:auto;background:linear-gradient(135deg,rgba(37,99,235,.25),rgba(124,58,237,.18));border:1px solid rgba(255,255,255,.12);border-radius:24px;padding:18px}.sideBox p{margin:7px 0 0;color:#b9c5d6;font-size:13px}main{padding:28px;overflow:hidden}.topbar{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px}.eyebrow{font-size:12px;font-weight:900;text-transform:uppercase;letter-spacing:.08em;color:#2563eb;margin:0}.topbar h2{font-size:30px;margin:3px 0 0}.userPill{display:flex;align-items:center;gap:10px;background:white;border:1px solid #e2e8f0;border-radius:999px;padding:10px 14px;font-weight:800}.userPill span{width:10px;height:10px;background:#22c55e;border-radius:999px}.hero{border-radius:34px;padding:36px;min-height:330px;display:grid;grid-template-columns:1.4fr .6fr;gap:28px;align-items:end}.premium{background:radial-gradient(circle at 10% 0%,rgba(59,130,246,.55),transparent 31%),linear-gradient(135deg,#020617,#101b34 58%,#162252);color:white;box-shadow:0 28px 70px rgba(2,6,23,.22)}.chip{display:inline-block;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:10px 14px;color:#dbeafe;font-weight:850}.hero h1{font-size:62px;line-height:.98;max-width:850px;margin:24px 0 18px;letter-spacing:-.055em}.hero p{color:#dbeafe;font-size:19px;max-width:680px}.actions{display:flex;gap:12px;margin-top:26px}.heroPanel{background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.14);border-radius:28px;padding:24px}.heroPanel strong{display:block;font-size:34px}.heroPanel span{color:#dbeafe}.progress{height:10px;background:rgba(255,255,255,.12);border-radius:99px;margin:22px 0 10px;overflow:hidden}.progress i{display:block;height:100%;background:linear-gradient(90deg,#60a5fa,#a78bfa);border-radius:99px}.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:18px;margin:22px 0}.stat,.card{background:white;border:1px solid #e2e8f0;box-shadow:0 20px 60px rgba(15,23,42,.06)}.stat{border-radius:28px;padding:22px}.stat.accent{background:#08111f;color:white}.stat p{color:#64748b;margin:0}.stat.accent p,.stat.accent span{color:#cbd5e1}.stat strong{display:block;font-size:29px;margin:8px 0 8px}.stat span{color:#64748b}.grid2{display:grid;grid-template-columns:1.35fr .65fr;gap:22px}.card{border-radius:30px;padding:22px;margin-bottom:22px;overflow:auto}.cardHead{display:flex;align-items:center;justify-content:space-between;gap:16px;margin-bottom:16px}.cardHead h3{font-size:23px;margin:0}.actionRow{display:flex;gap:10px;align-items:center}.toolbar{margin-bottom:16px}table{width:100%;border-collapse:collapse}th,td{padding:14px;border-bottom:1px solid #edf2f7;text-align:left;white-space:nowrap}th{font-size:12px;text-transform:uppercase;letter-spacing:.05em;color:#64748b;background:#f8fafc}.badge{display:inline-flex;border-radius:999px;background:#eef2ff;color:#3730a3;padding:7px 10px;font-size:12px;font-weight:900}.badge.ok{background:#dcfce7;color:#166534}.badge.warn{background:#fef3c7;color:#92400e}.checklist{display:grid;gap:11px}.checklist div{display:flex;gap:10px;align-items:center;background:#f8fafc;border:1px solid #edf2f7;border-radius:16px;padding:13px;font-weight:750}.checklist span{display:grid;place-items:center;width:24px;height:24px;border-radius:999px;background:#dcfce7;color:#166534;font-weight:900}.accountGrid,.settingsGrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:14px}.account{border:1px solid #e2e8f0;border-radius:20px;padding:18px;background:#f8fafc}.account strong{display:block;color:#2563eb;font-size:24px}.profile{display:flex;align-items:center;gap:18px;margin-bottom:22px}.avatar{width:70px;height:70px;border-radius:24px;background:linear-gradient(135deg,#2563eb,#7c3aed);color:white;display:grid;place-items:center;font-size:24px;font-weight:900}.modal{position:fixed;inset:0;background:rgba(2,6,23,.65);display:grid;place-items:center;padding:22px;z-index:10}.modalCard{position:relative;width:min(520px,100%);background:white;border-radius:30px;padding:28px;box-shadow:0 30px 100px rgba(2,6,23,.35);display:grid;gap:13px}.close{position:absolute;top:15px;right:15px;width:38px;height:38px;border:0;border-radius:999px;background:#f1f5f9;font-size:24px}.modalCard h2{margin:0 0 8px}@media(max-width:1050px){.app{grid-template-columns:1fr}.sidebar{position:relative;height:auto;display:grid;grid-template-columns:1fr 1fr}.brand,.sideBox{grid-column:1/-1}.hero,.grid2{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,1fr)}}@media(max-width:680px){main{padding:16px}.topbar{align-items:flex-start;gap:12px;flex-direction:column}.hero{padding:24px}.hero h1{font-size:42px}.stats{grid-template-columns:1fr}.sidebar{grid-template-columns:1fr}.actions,.cardHead{flex-direction:column;align-items:stretch}.actionRow{width:100%;flex-direction:column}.primary,.ghost{width:100%}}
